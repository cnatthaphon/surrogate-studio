      "v0Range": [-1.0, 1.0]
    },
    "pendulum": {
      "mRange": [0.5, 2.0],
      "cRange": [0.05, 0.8],
      "lRange": [0.8, 2.5],
      "x0Range": [-0.8, 0.8],
      "v0Range": [-1.0, 1.0]
    },
    "bouncing": {
      "mRange": [0.5, 3.0],
      "cRange": [0.01, 0.25],
      "eRange": [0.6, 0.95],
      "x0Range": [0.0, 2.0],
      "v0Range": [0.5, 6.0],
      "g": 9.81,
      "groundModel": "compliant",
