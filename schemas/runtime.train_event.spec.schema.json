{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://cnatthaphon.github.io/comphys/oscillator-surrogate/schemas/runtime.train_event.spec.schema.json",
  "title": "Oscillator Runtime Train Event Spec v1",
  "type": "object",
  "additionalProperties": false,
  "required": ["irVersion", "kind", "ts", "runtimeId", "runtime"],
  "properties": {
    "irVersion": { "type": "string", "const": "1.0" },
    "kind": {
      "type": "string",
      "enum": [
        "handshake_ok",
        "handshake_failed",
        "run_started",
        "epoch_end",
        "run_completed",
        "run_failed",
        "run_skipped"
      ]
    },
    "ts": { "type": "number" },
    "sessionId": { "type": "string" },
    "runtimeId": {
      "type": "string",
      "enum": [
        "js_client",
        "server_tfjs",
        "server_pytorch_gpu",
        "server_pytorch_cpu",
        "python_server",
        "node_server",
        "notebook_local"
      ]
    },
    "runtime": {
      "type": "object",
      "additionalProperties": false,
      "required": ["host", "engine", "backend", "transport"],
      "properties": {
        "host": { "type": "string", "enum": ["browser", "server", "node", "unknown"] },
        "engine": { "type": "string", "enum": ["tfjs", "pytorch", "django_worker", "unknown"] },
        "backend": { "type": "string", "minLength": 1 },
        "transport": { "type": "string", "enum": ["inproc", "ws", "http_poll", "http", "unknown"] }
      }
    },
    "status": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "state": { "type": "string", "enum": ["ready", "running", "completed", "error", "skipped"] },
        "message": { "type": "string" }
      }
    },
    "metrics": {
      "type": "object",
      "additionalProperties": true,
      "properties": {
        "epoch": { "type": "integer", "minimum": 1 },
        "train_loss": { "type": "number" },
        "val_loss": { "type": "number" },
        "lr": { "type": "number" },
        "best_val_loss": { "type": "number" },
        "improved": { "type": "boolean" },
        "val_mae": { "type": "number" },
        "test_mae": { "type": "number" },
        "best_epoch": { "type": "number" },
        "final_lr": { "type": "number" }
      }
    },
    "reason": { "type": "string" },
    "mode": { "type": "string" },
    "modelFamily": { "type": "string" },
    "train": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "train_size": { "type": "integer", "minimum": 0 },
        "val_size": { "type": "integer", "minimum": 0 },
        "test_size": { "type": "integer", "minimum": 0 },
        "loss": { "type": "string" }
      }
    },
    "handshake": {
      "type": "object",
      "additionalProperties": true,
      "properties": {
        "ok": { "type": "boolean" },
        "runtimeId": { "type": "string" },
        "backend": { "type": "string" },
        "transport": { "type": "string" },
        "backendAvailability": {
          "type": "object",
          "additionalProperties": { "type": "boolean" }
        }
      }
    }
  }
}
